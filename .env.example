# Shared
NODE_ENV=development

# Postgres (Docker Compose)
POSTGRES_USER=app
POSTGRES_PASSWORD=app
POSTGRES_DB=dutydb
DATABASE_URL=postgresql://app:app@postgres:5432/dutydb?schema=public

# Backend
BACKEND_PORT=4000
JWT_SECRET=change_me_in_production
JWT_EXPIRES_IN=7d
FRONTEND_URL=http://localhost:5173

# Seed manager credentials (auto-created if not exists)
MANAGER_LOGIN=manager
MANAGER_PASSWORD=12345

# Google OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:4000/api/auth/google/callback

# Google APIs (optional, service account or OAuth tokens)
# If you use OAuth tokens: set GOOGLE_REFRESH_TOKEN and GOOGLE_OAUTH_CLIENT_EMAIL not needed
GOOGLE_REFRESH_TOKEN=

# For service account JSON (recommended in prod): mount file and point here
GOOGLE_SERVICE_ACCOUNT_KEY_PATH=/run/secrets/google_service_account.json

# Google target resources
GOOGLE_CALENDAR_ID=primary
GOOGLE_SHEETS_ID=
GOOGLE_SHEETS_RANGE=Sheet1!A:Z
GOOGLE_DOCS_TEMPLATE_ID=
GOOGLE_DRIVE_FOLDER_ID=

